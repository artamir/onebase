Процедура ПриЗаписи()
  Если this.Поставщик = "" Тогда
    Error("Укажите поставщика");
  КонецЕсли;
  Если this.Склад = "" Тогда
    Error("Укажите склад");
  КонецЕсли;
  Если this.Товары.Количество() = 0 Тогда
    Error("Добавьте хотя бы одну строку в табличную часть Товары");
  КонецЕсли;
КонецПроцедуры
