// Поступление на расчётный счёт:
//   Дт 51 — Кт 62  (от покупателя)
//   Дт 51 — Кт 90.1  (прочий доход)
Процедура ОбработкаПроведения()
  Движения.БухУчёт.Очистить();

  Дв = Движения.БухУчёт.Добавить();
  Дв.СчётДт = "51";
  Дв.Сумма  = this.Сумма;
  Дв.Период = this.Дата;

  Если this.ВидПлатежа = "ОплатаОтПокупателя" Тогда
    Дв.СчётКт = "62";
  Иначе
    Дв.СчётКт = "91.1";
  КонецЕсли;
КонецПроцедуры
