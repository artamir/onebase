// Авансовый отчёт — списание подотчётных сумм:
//   Дт <счёт> — Кт 71  (по каждой строке расходов)
Процедура ОбработкаПроведения()
  Движения.БухУчёт.Очистить();

  Для Каждого Стр Из this.Расходы Цикл
    Дв = Движения.БухУчёт.Добавить();
    Дв.СчётДт = Стр.СчётУчёта;
    Дв.СчётКт = "71";
    Дв.Сумма  = Стр.Сумма;
    Дв.Период = this.Дата;
  КонецЦикла;
КонецПроцедуры
